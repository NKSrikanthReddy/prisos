// timeFormat.js — formats pickup window for display
 
/**
* Formats two ISO date strings into a human-friendly pickup window.
* Example output: "Pickup between 8:30 – 9:30 PM"
*
* @param {string} startISO  - pickupStart from the API (e.g. '2025-08-01T20:30:00.000Z')
* @param {string} endISO    - pickupEnd from the API
* @returns {string}         - formatted label, or 'Pickup window unavailable'
*/
export const formatPickupWindow = (startISO, endISO) => {
 if (!startISO || !endISO) return 'Pickup window unavailable';
 
 const opts = { hour: 'numeric', minute: '2-digit', hour12: true };
 const start = new Date(startISO).toLocaleTimeString('en-IN', opts);
 const end   = new Date(endISO).toLocaleTimeString('en-IN', opts);
 
 return `Pickup between ${start} – ${end}`;
 // e.g. → "Pickup between 8:30 PM – 9:30 PM"
};
 
/**
* Returns true if the pickup window is still open (now is before pickupEnd).
* Used to grey-out or hide items that have passed their window.
*/
export const isPickupOpen = (endISO) => {
 if (!endISO) return false;
 return new Date(endISO) > new Date();
};
 
/**
* Returns a short urgency label shown as a badge on the food card.
* Examples: '⏰ Closes in 23 min'  or  '🟢 Open until 9:30 PM'
*/
export const pickupUrgencyLabel = (endISO) => {
 if (!endISO) return '';
 const minsLeft = Math.floor((new Date(endISO) - new Date()) / 60000);
 if (minsLeft <= 0)  return '🔴 Pickup closed';
 if (minsLeft <= 30) return `⏰ Closes in ${minsLeft} min`;
 const endTime = new Date(endISO).toLocaleTimeString('en-IN',
   { hour: 'numeric', minute: '2-digit', hour12: true });
 return `🟢 Open until ${endTime}`;
};